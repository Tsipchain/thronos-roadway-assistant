# ─── Database (Neon PostgreSQL, eu-central-1) ───────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/roadway?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/roadway?sslmode=require"

# ─── Redis (Railway) ─────────────────────────────────────────────────────────
# Get from Railway dashboard → Redis → Variables → REDIS_URL
REDIS_URL="redis://default:password@switchyard.proxy.rlwy.net:PORT"

# ─── Auth ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://roadway.thronoschain.org"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Stripe (fiat EUR subscriptions & invoices) ───────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Webhook endpoint to register in Stripe: https://roadway.thronoschain.org/api/stripe/webhook
# Events: checkout.session.completed

# ─── Thronos Chain (thrchain.up.railway.app) ─────────────────────────────────
THRONOS_NODE_URL="https://thrchain.up.railway.app"
THRONOS_PLATFORM_ADDRESS="THR..."
THRONOS_PLATFORM_KEY="..."
ADMIN_SECRET="..."

# ─── BTC Pledge Vault ────────────────────────────────────────────────────────
BTC_PLEDGE_VAULT="bc1q..."

# ─── P2P BTC Desk ────────────────────────────────────────────────────────────
P2P_SPREAD_PCT="1.5"
P2P_FLAT_FEE_EUR="2"
P2P_BANK_IBAN="GR..."
P2P_BANK_BENEFICIARY="Thronos Chain"
P2P_BANK_BIC="ETHNGRAA"

# ─── Exchange Rate providers ─────────────────────────────────────────────────
# Fallback chain: Binance → Kraken → CoinGecko (automatic)
# EXCHANGE_PROVIDER="binance"         # optional override

# ─── Cloudflare / Vercel ─────────────────────────────────────────────────────
# Add CNAME: roadway → cname.vercel-dns.com
# SSL: Full Strict
# Vercel project domain: roadway.thronoschain.org
