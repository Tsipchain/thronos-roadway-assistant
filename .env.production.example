# Production template. Copy values into your hosting provider secrets, not into Git.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
NEXTAUTH_URL="https://YOUR_APP_DOMAIN"
NEXTAUTH_SECRET="GENERATE_A_LONG_RANDOM_SECRET"

NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
GOOGLE_DISTANCE_MATRIX_KEY=""
NEXT_PUBLIC_MAPBOX_TOKEN=""

STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PK=""
STRIPE_WEBHOOK_SECRET=""

THRONOS_NODE_URL="https://thrchain.up.railway.app"
THRONOS_GATEWAY_URL="https://thronoschain.vercel.app"
THRONOS_EVM_RPC_URL="https://YOUR_NATIVE_THRONOS_EVM_RPC"
NEXT_PUBLIC_THRONOS_EVM_RPC_URL="https://YOUR_NATIVE_THRONOS_EVM_RPC"
THRONOS_CHAIN_ID="YOUR_CHAIN_ID"
NEXT_PUBLIC_THRONOS_CHAIN_ID="YOUR_CHAIN_ID"
NEXT_PUBLIC_THRONOS_CHAIN_NAME="Thronos EVM"
NEXT_PUBLIC_THRONOS_NATIVE_SYMBOL="THR"
NEXT_PUBLIC_THRONOS_EXPLORER_URL="https://YOUR_THRONOS_EXPLORER"

# Keep these only in secret storage. Never expose them through NEXT_PUBLIC_*.
THRONOS_DEPLOYER_PRIVATE_KEY="SET_IN_SECRET_STORE_ONLY"
THRONOS_PLATFORM_PRIVATE_KEY="SET_IN_SECRET_STORE_ONLY"
THRONOS_PLATFORM_WALLET="0xYOUR_PLATFORM_PUBLIC_ADDRESS"

THRONOS_ESCROW_CONTRACT="0x0000000000000000000000000000000000000000"
THRONOS_SERVICEBOOK_CONTRACT="0x0000000000000000000000000000000000000000"
THRONOS_REWARD_VAULT_CONTRACT="0x0000000000000000000000000000000000000000"
THRONOS_REWARD_TOKEN_ADDRESS="0x0000000000000000000000000000000000000000"

THRONOS_ATTESTATION_ENABLED="true"
THRONOS_ATTESTATION_ENDPOINT="https://thrchain.up.railway.app/api/commerce/attest"
THRONOS_ATTESTATION_API_KEY="SET_IN_SECRET_STORE_ONLY"

VEHICLE_API_URL=""
VEHICLE_API_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@YOUR_DOMAIN"
NEXT_PUBLIC_WS_URL="wss://YOUR_APP_DOMAIN"
DEFAULT_TECHNICIAN_PASSWORD="SET_TEMP_PASSWORD_AND_FORCE_RESET"
