{
  "name": "thronos-roadside-assist",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "chain:compile": "hardhat compile",
    "chain:verify-env": "tsx scripts/verify-thronos-env.ts",
    "chain:deploy:thronos": "hardhat run scripts/deploy-thronos.ts --network thronos",
    "chain:deploy:local": "hardhat run scripts/deploy-thronos.ts --network localhost",
    "import:real-data": "tsx scripts/import-real-data.ts",
    "import:real-data:templates": "tsx scripts/import-real-data.ts data/templates",
    "chain:health": "curl -s ${THRONOS_EVM_RPC_URL} -H \"Content-Type: application/json\" -d '{\"jsonrpc\":\"2.0\",\"method\":\"eth_chainId\",\"params\":[],\"id\":1}'"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "next-auth": "^4.24.11",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "jsonwebtoken": "^9.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.5",
    "leaflet": "^1.9.4",
    "@types/leaflet": "^1.9.14",
    "react-leaflet": "^4.2.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "ethers": "^6.13.4",
    "stripe": "^17.4.0",
    "@stripe/stripe-js": "^4.9.0",
    "recharts": "^2.13.3",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "date-fns": "^4.1.0",
    "qrcode": "^1.5.4",
    "@types/qrcode": "^1.5.5",
    "firebase-admin": "^13.0.1",
    "web-push": "^3.6.7",
    "@types/web-push": "^3.6.4",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "tsx": "^4.19.2",
    "hardhat": "^2.22.18",
    "@nomicfoundation/hardhat-ethers": "^3.0.8"
  }
