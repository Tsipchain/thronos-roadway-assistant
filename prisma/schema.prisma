generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  TECHNICIAN
  ADMIN
  SUPER_ADMIN
}

enum RequestStatus {
  PENDING
  ACCEPTED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CARD
  CRYPTO
  CASH
}

enum PaymentStatus {
  PENDING
  ESCROWED
  COMPLETED
  REFUNDED
  FAILED
}

enum ServiceType {
  BATTERY_REPLACEMENT
  BATTERY_CHARGE
  TIRE_CHANGE
  TIRE_REPAIR
  DIAGNOSIS
}

enum TeamMemberRole {
  EMPLOYEE
  CONTRACTOR
  PARTNER
  MANAGER
}

enum P2POrderStatus {
  QUOTE       // price locked, awaiting EUR payment
  PAID        // EUR received, BTC send pending
  SENT        // BTC sent on-chain
  COMPLETED   // confirmed
  EXPIRED     // quote expired before payment
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  phone         String         @unique
  passwordHash  String
  name          String
  role          UserRole       @default(CUSTOMER)
  avatarUrl     String?
  walletAddress String?        @unique
  tenantId      String?
  tenant        PartnerCompany? @relation("TenantUsers", fields: [tenantId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  vehicles          Vehicle[]
  requests          ServiceRequest[]  @relation("CustomerRequests")
  reviews           Review[]          @relation("CustomerReviews")
  subscriptions     Subscription[]
  technicianProfile TechnicianProfile?
  assignedRequests  ServiceRequest[]  @relation("TechnicianRequests")
  receivedReviews   Review[]          @relation("TechnicianReviews")
  dispatchAttempts  DispatchAttempt[] @relation("TechnicianDispatchAttempts")
  rewardBalance     Float             @default(0)
  rewardHistory     RewardEvent[]
  pushSubscriptions PushSubscription[]
  p2pOrders         P2POrder[]
}

model TechnicianProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id])
  isOnline         Boolean         @default(false)
  isAvailable      Boolean         @default(true)
  latitude         Float?
  longitude        Float?
  lastLocationAt   DateTime?
  rating           Float           @default(5.0)
  totalJobs        Int             @default(0)
  specialties      ServiceType[]
  coverageRadiusKm Float           @default(15)
  vehiclePlate     String?
  inventoryNote    String?
  companyId        String?
  company          PartnerCompany? @relation(fields: [companyId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Vehicle {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  licensePlate String
  make         String
  model        String
  year         Int
  engineType   String?
  batteryType  String?
  batteryAh    Int?
  tireSize     String?
  vin          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requests       ServiceRequest[]
  serviceRecords ServiceRecord[]

  @@unique([userId, licensePlate])
}

model ServiceRequest {
  id           String          @id @default(cuid())
  customerId   String
  customer     User            @relation("CustomerRequests", fields: [customerId], references: [id])
  technicianId String?
  technician   User?           @relation("TechnicianRequests", fields: [technicianId], references: [id])
  vehicleId    String
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id])
  tenantId     String?
  tenant       PartnerCompany? @relation("TenantRequests", fields: [tenantId], references: [id])

  serviceType      ServiceType
  status           RequestStatus @default(PENDING)
  description      String?
  symptoms         String[]
  latitude         Float
  longitude        Float
  address          String?
  createdAt        DateTime      @default(now())
  acceptedAt       DateTime?
  arrivedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  estimatedMinutes Int?
  estimatedPrice   Float?
  finalPrice       Float?

  payment          Payment?
  serviceRecord    ServiceRecord?
  review           Review?
  dispatchAttempts DispatchAttempt[]

  txHash           String?
  escrowTxHash     String?
  completionTxHash String?
  attestationHash  String?
  attestationTxId  String?

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model Payment {
  id              String         @id @default(cuid())
  requestId       String         @unique
  request         ServiceRequest @relation(fields: [requestId], references: [id])
  method          PaymentMethod
  status          PaymentStatus  @default(PENDING)
  amount          Float
  currency        String         @default("EUR")
  stripePaymentId String?
  cryptoTxHash    String?
  escrowAddress   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ServiceRecord {
  id               String         @id @default(cuid())
  requestId        String         @unique
  request          ServiceRequest @relation(fields: [requestId], references: [id])
  vehicleId        String
  vehicle          Vehicle        @relation(fields: [vehicleId], references: [id])
  serviceType      ServiceType
  description      String
  partsUsed        String[]
  technicianNotes  String?
  blockchainTxHash String?
  attestationHash  String?
  attestationTxId  String?
  createdAt        DateTime       @default(now())
}

model Review {
  id           String         @id @default(cuid())
  requestId    String         @unique
  request      ServiceRequest @relation(fields: [requestId], references: [id])
  customerId   String
  customer     User           @relation("CustomerReviews", fields: [customerId], references: [id])
  technicianId String
  technician   User           @relation("TechnicianReviews", fields: [technicianId], references: [id])
  rating       Int
  comment      String?
  createdAt    DateTime       @default(now())
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  plan        String   @default("annual")
  priceEur    Float    @default(30)
  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime
  stripeSubId String?
  createdAt   DateTime @default(now())
}

model RewardEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  reason    String
  txHash    String?
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model PricingRule {
  id               String          @id @default(cuid())
  tenantId         String?
  tenant           PartnerCompany? @relation(fields: [tenantId], references: [id])
  serviceType      ServiceType
  basePrice        Float
  perKmSurcharge   Float           @default(0.5)
  nightSurcharge   Float           @default(10)
  weekendSurcharge Float           @default(5)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([serviceType, tenantId])
}

model PartnerCompany {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique
  logoUrl         String?
  vatNumber       String?
  phone           String?
  email           String?
  billingAddress  String?
  plan            String    @default("starter")
  planActiveUntil DateTime?
  status          String    @default("ACTIVE")

  // Thronos Chain
  thrWalletAddress     String?  @unique
  btcPledgeAddress     String?
  btcPledgeVerified    Float    @default(0)
  pledgeVerifiedAt     DateTime?
  enterpriseEnabled    Boolean  @default(false)
  thrRewardPoolBalance Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  technicians  TechnicianProfile[]
  serviceAreas ServiceArea[]
  users        User[]            @relation("TenantUsers")
  requests     ServiceRequest[]  @relation("TenantRequests")
  pricingRules PricingRule[]
  teamMembers  TenantTeamMember[]
  rewardTxs    TenantRewardTx[]
  p2pOrders    P2POrder[]
  invoices     TenantInvoice[]
}

model TenantTeamMember {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          PartnerCompany @relation(fields: [tenantId], references: [id])
  name            String
  phone           String?
  email           String?
  role            TeamMemberRole @default(EMPLOYEE)
  thrAddress      String?        @unique
  thrBalance      Float          @default(0)
  totalEarned     Float          @default(0)
  isActive        Boolean        @default(true)
  walletCreatedAt DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  rewardTxs TenantRewardTx[]

  @@index([tenantId])
  @@index([thrAddress])
}

model TenantRewardTx {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    PartnerCompany   @relation(fields: [tenantId], references: [id])
  memberId  String
  member    TenantTeamMember @relation(fields: [memberId], references: [id])
  amount    Float
  reason    String
  txHash    String?
  status    String           @default("PENDING")
  createdAt DateTime         @default(now())

  @@index([tenantId, createdAt])
  @@index([memberId])
}

// P2P BTC desk — partner buys BTC from platform hot wallet, pays EUR
model P2POrder {
  id              String        @id @default(cuid())
  tenantId        String?
  tenant          PartnerCompany? @relation(fields: [tenantId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])

  // Quote
  btcAmount       Float         // BTC to receive
  eurAmount       Float         // EUR to pay
  rateEurPerBtc   Float         // locked rate
  feeEur          Float         @default(0)  // platform spread/fee
  quoteExpiresAt  DateTime

  // Payment
  status          P2POrderStatus @default(QUOTE)
  paymentRef      String?       // bank transfer ref or Stripe PI id
  paymentMethod   String        @default("bank") // bank | card
  paidAt          DateTime?

  // BTC delivery
  destinationBtc  String        // partner's BTC address
  btcTxHash       String?       // on-chain send tx
  sentAt          DateTime?
  confirmedAt     DateTime?

  exchangeOrderId String?       // ref from exchange
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId, status])
  @@index([status, quoteExpiresAt])
}

// Fiat invoices for platform subscription / services (paid by tenant in EUR)
model TenantInvoice {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        PartnerCompany @relation(fields: [tenantId], references: [id])

  number        String        @unique  // INV-2025-001
  description   String
  amountEur     Float
  vatPct        Float         @default(24)
  totalEur      Float

  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime
  paidAt        DateTime?
  stripePaymentId String?
  paymentMethod String?       // stripe | bank
  bankRef       String?       // bank transfer ref

  lineItems     Json          // [{ description, qty, unitPrice }]
  notes         String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantId, status])
}

model ServiceArea {
  id              String          @id @default(cuid())
  companyId       String?
  company         PartnerCompany? @relation(fields: [companyId], references: [id])
  name            String
  country         String          @default("GR")
  city            String
  centerLatitude  Float
  centerLongitude Float
  radiusKm        Float           @default(15)
  serviceTypes    ServiceType[]
  slaMinutes      Int             @default(30)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([name, city])
  @@index([city, isActive])
}

model BatteryCatalogItem {
  id             String               @id @default(cuid())
  sku            String               @unique
  brand          String
  model          String
  technology     String
  voltage        Int                  @default(12)
  ah             Int
  cca            Int?
  lengthMm       Int?
  widthMm        Int?
  heightMm       Int?
  polarity       String?
  warrantyMonths Int                  @default(24)
  retailPriceEur Float
  partnerCostEur Float?
  platformFeeEur Float                @default(0)
  stockNote      String?
  isActive       Boolean              @default(true)
  fitments       VehicleFitmentRule[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model TyreCatalogItem {
  id             String               @id @default(cuid())
  sku            String               @unique
  brand          String
  model          String
  size           String
  season         String
  loadIndex      String?
  speedIndex     String?
  warrantyMonths Int                  @default(12)
  retailPriceEur Float
  partnerCostEur Float?
  platformFeeEur Float                @default(0)
  stockNote      String?
  isActive       Boolean              @default(true)
  fitments       VehicleFitmentRule[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model VehicleFitmentRule {
  id          String              @id @default(cuid())
  sourceKey   String?             @unique
  make        String
  model       String
  yearFrom    Int?
  yearTo      Int?
  engineType  String?
  batterySku  String?
  batteryItem BatteryCatalogItem? @relation(fields: [batterySku], references: [sku])
  tyreSku     String?
  tyreItem    TyreCatalogItem?    @relation(fields: [tyreSku], references: [sku])
  tyreSize    String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([make, model])
  @@index([batterySku])
  @@index([tyreSku])
}

model DispatchAttempt {
  id               String         @id @default(cuid())
  requestId        String
  request          ServiceRequest @relation(fields: [requestId], references: [id])
  technicianId     String
  technician       User           @relation("TechnicianDispatchAttempts", fields: [technicianId], references: [id])
  radiusKm         Float
  distanceKm       Float
  estimatedMinutes Int
  status           String         @default("NOTIFIED")
  notifiedAt       DateTime       @default(now())
  respondedAt      DateTime?

  @@index([requestId])
  @@index([technicianId, status])
}

model AttestationRecord {
  id          String   @id @default(cuid())
  type        String
  subjectId   String
  mode        String
  hash        String
  txId        String?
  txHash      String?
  payloadJson Json
  rawJson     Json?
  createdAt   DateTime @default(now())

  @@index([subjectId])
  @@index([hash])
}
