# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/battery_assist"

# Redis (Railway)
REDIS_URL="redis://default:password@switchyard.proxy.rlwy.net:PORT"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-google-maps-api-key"
GOOGLE_DISTANCE_MATRIX_KEY="your-distance-matrix-key"
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Stripe / fiat payments
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PK="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Thronos native EVM + SHA-256 attestation
# -----------------------------------------------------------------------------
THRONOS_NODE_URL="https://thrchain.up.railway.app"
THRONOS_GATEWAY_URL="https://thronoschain.vercel.app"

THRONOS_EVM_RPC_URL="https://YOUR_THRONOS_EVM_RPC_URL"
NEXT_PUBLIC_THRONOS_EVM_RPC_URL="https://YOUR_THRONOS_EVM_RPC_URL"

THRONOS_CHAIN_ID="YOUR_CHAIN_ID"
NEXT_PUBLIC_THRONOS_CHAIN_ID="YOUR_CHAIN_ID"
NEXT_PUBLIC_THRONOS_CHAIN_NAME="Thronos EVM"
NEXT_PUBLIC_THRONOS_NATIVE_SYMBOL="THR"
NEXT_PUBLIC_THRONOS_EXPLORER_URL="https://YOUR_THRONOS_EXPLORER"

THRONOS_DEPLOYER_PRIVATE_KEY="0x..."
THRONOS_PLATFORM_PRIVATE_KEY="0x..."
THRONOS_PLATFORM_WALLET="0x..."

THRONOS_ESCROW_CONTRACT="0x0000000000000000000000000000000000000000"
THRONOS_SERVICEBOOK_CONTRACT="0x0000000000000000000000000000000000000000"
THRONOS_REWARD_VAULT_CONTRACT="0x0000000000000000000000000000000000000000"
THRONOS_REWARD_TOKEN_ADDRESS="0x0000000000000000000000000000000000000000"

THRONOS_ATTESTATION_ENABLED="true"
THRONOS_ATTESTATION_MODE="sha256-node"
THRONOS_ATTESTATION_ENDPOINT="https://thrchain.up.railway.app/api/commerce/attest"
THRONOS_ATTESTATION_API_KEY="shared-secret-with-thronos-node"

NEXT_PUBLIC_THRONOSCHAIN_RPC="https://YOUR_THRONOS_EVM_RPC_URL"
THRONOSCHAIN_PRIVATE_KEY="0x..."
ESCROW_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
SERVICE_BOOK_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
REWARD_TOKEN_ADDRESS="0x0000000000000000000000000000000000000000"

# Vehicle Data API
VEHICLE_API_KEY="your-vehicle-data-api-key"
VEHICLE_API_URL="https://api.vehicledata.eu/v1"

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@batterysos.gr"

# WebSocket Server
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
